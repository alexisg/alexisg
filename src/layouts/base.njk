{%- set notHome = (page.url != '/') -%}
{%- set isHome = (page.url == '/') -%}

<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1">
    <title>
        Alexis Gallisá{% if notHome %} - {{title}}{% endif %}
    </title>
    <meta name="viewport" content="width=device-width" />
    <meta property="og:url" content="https://www.alexisgallisa.com"/>
    <meta property="og:title" content="Alexis Gallisá{% if notHome %} -{% endif %}{{title}}"/>
    <meta name="og:description" content="{% block description %}I shape and guide design teams that thrive on collaboration and high craft. I’m most at home in complex product spaces, refining pixel-level UI details and the milliseconds that create fluid interactions, energized by the limitless potential of AI-driven design workflows.{% endblock %}" />
    <meta property="og:site_name" content="SwiftKey"/>
    <meta property="og:image" content="https://www.alexisgallisa.com/static/images/preview.png"/>
    <link rel="icon" href="https://www.alexisgallisa.com/static/images/favicon.png"/>
    <link rel="apple-touch-icon" href="https://www.alexisgallisa.com/static/images/apple-touch-icon.png"/>
    <link rel="stylesheet" href="https://use.typekit.net/bal5xca.css">
    <script>
      (function () {
        try {
          var key = 'theme';
          var stored = localStorage.getItem(key);
          var prefersDark = window.matchMedia && window
            .matchMedia('(prefers-color-scheme: dark)')
            .matches;
          var theme = stored || (
            prefersDark
            ? 'dark'
            : 'light');
          if (theme) {
            document
              .documentElement
              .setAttribute('data-theme', theme);
          }
        } catch (e) {
          if (window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches) {
            document
              .documentElement
              .setAttribute('data-theme', 'dark');
          }
        }
      })();
    </script>
    <link rel="stylesheet" href="/static/css/theme.css"/>
    <link rel="stylesheet" href="/sass/alexis.css"/>
    {% block head_extra %}{% endblock %}
  </head>

  <body>

    {% include "sprite.svg" %}

    {% include "themepicker.njk" %}

    <div id="js-main" data-page="home">
      <div class="container">

        {% include "header.njk" %}

        {% block extra %}{% endblock %}

        <article>
          {% block nav %}
            {% include "nav.njk" %}
          {% endblock %}
          {{ content | safe }}
        </article>

        {% include "footer.njk" %}

      </div>
    </div>

    <script src="/static/js/tornis.es5.js"></script>
    <script src="/static/js/main.js"></script>
    <script src="/static/js/viewTransitions.js"></script>
    <script src="/static/js/themePicker.js"></script>

    {% block js_extra %}{% endblock %}

    <!-- =^.^= -->

  </body>
</html>